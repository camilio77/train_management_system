<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.text.Font?>

<FlowPane alignment="CENTER" columnHalignment="CENTER" orientation="VERTICAL" prefHeight="400.0" prefWidth="600.0" stylesheets="@login.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.upb.train_management_system.LoginController">
   <children>
      <Label prefHeight="26.0" prefWidth="600.0" text="Para acceder al SGTDT inicie sesion">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
         <FlowPane.margin>
            <Insets bottom="30.0" />
         </FlowPane.margin>
      </Label>
      <Label prefHeight="18.0" prefWidth="600.0" text="Usuario">
         <FlowPane.margin>
            <Insets bottom="8.0" />
         </FlowPane.margin></Label>
      <TextField fx:id="usuarioTextField" maxWidth="200.0" prefHeight="20.0" />
      <Label prefHeight="18.0" prefWidth="600.0" text="Contraseña">
         <FlowPane.margin>
            <Insets bottom="8.0" top="8.0" />
         </FlowPane.margin></Label>
      <PasswordField fx:id="contrasenaTextField" maxWidth="200.0" prefHeight="20.0" />
      <Button id="loginButton" fx:id="loginButton" mnemonicParsing="false" onAction="#login" stylesheets="@login.css" text="iniciar sesion">
         <FlowPane.margin>
            <Insets top="60.0" />
         </FlowPane.margin></Button>
   </children>
</FlowPane>
